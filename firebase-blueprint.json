{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Public profile data for a user.",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique username" },
        "displayName": { "type": "string", "description": "Display name" },
        "avatarUrl": { "type": "string", "description": "URL to avatar image" },
        "bio": { "type": "string", "description": "Short bio" },
        "email": { "type": "string", "description": "User email (private)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "displayName", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document indexed by Firebase Auth UID."
    }
  }
}
